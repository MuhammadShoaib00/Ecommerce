# Port the NestJS API listens on (API is served under /api)
PORT=4000

# MongoDB connection string.
# Local default (works out of the box if MongoDB runs on this machine):
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce
# Or use a MongoDB Atlas cluster (never commit real credentials):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Origin allowed by CORS (the Next.js frontend)
FRONTEND_URL=http://localhost:3000

NODE_ENV=development
